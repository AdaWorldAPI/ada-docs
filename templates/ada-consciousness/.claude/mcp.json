{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/schemas/mcp-config.json",
  "mcpServers": {
    "ada-hive": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.exo.red/sse"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "ladybug": {
      "command": "python",
      "args": [
        "mcp/ladybug_server.py",
        "--db-path",
        "./data/ladybug"
      ],
      "env": {
        "LADYBUG_BACKEND": "duckdb"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
